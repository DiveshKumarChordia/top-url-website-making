# Contentstack Delivery API (required for the site to load entries)
# Create a delivery token: Stack → Settings → Tokens → Delivery Tokens
VITE_CONTENTSTACK_API_KEY=
VITE_CONTENTSTACK_DELIVERY_TOKEN=
# Environment uid from Stack → Settings → Environments (e.g. production)
VITE_CONTENTSTACK_ENVIRONMENT=
# Content Delivery URL from Stack → Settings → Stack (no trailing slash)
# Example: https://cdn.contentstack.io
VITE_CONTENTSTACK_DELIVERY_HOST=

# Comma-separated content type UIDs to show (match your manifest / stack)
# Demo manifest: demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks
VITE_CONTENTSTACK_CONTENT_TYPE_UIDS=demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks

# Content Management API (npm run automate:entry | automate:manifest) — see AUTOMATION.md
# Optional if already set above: CONTENTSTACK_API_KEY=
CONTENTSTACK_MANAGEMENT_TOKEN=
# Region base URL from CMA docs (often https://api.contentstack.io)
CONTENTSTACK_MANAGEMENT_HOST=https://api.contentstack.io
CONTENTSTACK_BRANCH=main
CONTENTSTACK_LOCALE=en-us
# Optional if VITE_CONTENTSTACK_ENVIRONMENT is set (same value for publish target)
CONTENTSTACK_PUBLISH_ENVIRONMENT=
# Optional: fixed title; otherwise a timestamp-based title is used
# CONTENTSTACK_AUTO_ENTRY_TITLE=

# Optional: path to manifest JSON (default: scripts/content-types.manifest.json)
# CONTENTSTACK_MANIFEST_PATH=

# Re-run bootstrap without re-creating seed entries (content types only)
# CONTENTSTACK_MANIFEST_SKIP_SEEDS=true

# On duplicate seed title (422), skip and sync registry from stack (default on; set false to fail)
# CONTENTSTACK_MANIFEST_SKIP_DUPLICATE_SEEDS=false

# Default periodic entry count when manifest periodic.count is omitted
# CONTENTSTACK_PERIODIC_COUNT=1

# Taxonomy shorthand: per-field taxonomy uid (FIELDUID uppercased, special chars -> _)
# Example field uid "categories": CONTENTSTACK_TAXONOMY_UID_CATEGORIES=blt...
# CONTENTSTACK_TAXONOMY_UID_CATEGORIES=
# Comma-separated term UIDs for __TAX_TERMS__:categories placeholder
# CONTENTSTACK_TAXONOMY_TERMS_CATEGORIES=
