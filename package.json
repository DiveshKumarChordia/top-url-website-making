{
  "name": "top-url-website-making",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "automate:entry": "node --env-file=.env scripts/create-and-publish-entry.mjs",
    "automate:manifest": "node --env-file=.env scripts/bootstrap-from-manifest.mjs",
    "automate:entries:periodic": "node --env-file=.env scripts/periodic-entries-from-manifest.mjs",
    "automate:entries:periodic:ci": "node scripts/periodic-entries-from-manifest.mjs",
    "automate:workflows": "node --env-file=.env scripts/seed-workflows.mjs",
    "automate:locales-branches": "node --env-file=.env scripts/seed-locales-branches.mjs",
    "automate:bulk-publish": "node --env-file=.env scripts/bulk-publish-cycle.mjs",
    "automate:delete": "node --env-file=.env scripts/delete-old-entries.mjs",
    "automate:localize": "node --env-file=.env scripts/localize-entries.mjs",
    "automate:locale-experiments": "node --env-file=.env scripts/locale-experiments.mjs",
    "automate:publishing-rules": "node --env-file=.env scripts/seed-publishing-rules.mjs",
    "automate:ensure-role": "node --env-file=.env scripts/ensure-stack-user-role.mjs",
    "automate:churn": "node --env-file=.env scripts/churn-orphans.mjs",
    "automate:drive": "node --env-file=.env scripts/drive-all.mjs",
    "automate:drive:bootstrap": "node --env-file=.env scripts/drive-all.mjs --mode bootstrap",
    "automate:drive:full": "node --env-file=.env scripts/drive-all.mjs --mode full",
    "automate:drive:ci": "node scripts/drive-all.mjs",
    "org:list-users": "node --env-file=.env scripts/manage-org-permissions.mjs list-users",
    "org:list-roles": "node --env-file=.env scripts/manage-org-permissions.mjs list-roles",
    "org:promote": "node --env-file=.env scripts/manage-org-permissions.mjs promote",
    "org:demote": "node --env-file=.env scripts/manage-org-permissions.mjs demote",
    "org:remove": "node --env-file=.env scripts/manage-org-permissions.mjs remove",
    "org:invite": "node --env-file=.env scripts/manage-org-permissions.mjs invite",
    "org:check-role": "node --env-file=.env scripts/manage-org-permissions.mjs check-role",
    "automate:random-users": "node --env-file=.env scripts/automate-with-random-users.mjs",
    "automate:random-users:5": "node --env-file=.env scripts/automate-with-random-users.mjs --users 5 --operations 25",
    "automate:random-users:10": "node --env-file=.env scripts/automate-with-random-users.mjs --users 10 --operations 50",
    "warm:launch-urls": "node scripts/warm-launch-urls.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
