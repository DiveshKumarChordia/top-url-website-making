# =============================================================================
# Delivery API — required for npm run dev / build / Launch (see README)
# =============================================================================
VITE_CONTENTSTACK_API_KEY=
VITE_CONTENTSTACK_DELIVERY_TOKEN=
# Environment uid: Stack → Settings → Environments (e.g. production)
VITE_CONTENTSTACK_ENVIRONMENT=
# Content Delivery URL: Stack → Settings → Stack (no trailing slash), e.g. https://cdn.contentstack.io
VITE_CONTENTSTACK_DELIVERY_HOST=

# Optional — if your stack uses Branches, set the same branch as CONTENTSTACK_BRANCH (e.g. main)
# VITE_CONTENTSTACK_BRANCH=main

# -----------------------------------------------------------------------------
# Optional — omit to default the app to a single type: top_url_lines
# -----------------------------------------------------------------------------
# Comma-separated content type UIDs (match your stack / manifest)
# Demo manifest: demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks
VITE_CONTENTSTACK_CONTENT_TYPE_UIDS=demo_plain_text,demo_json_rte,demo_reference,demo_group,demo_blocks

# =============================================================================
# Content Management API — optional unless you run npm run automate:*
# =============================================================================
CONTENTSTACK_MANAGEMENT_TOKEN=
# Optional if VITE_CONTENTSTACK_API_KEY is set (either name works for scripts)
# CONTENTSTACK_API_KEY=

# Recommended: set for your stack (scripts use these defaults only if unset)
CONTENTSTACK_MANAGEMENT_HOST=https://api.contentstack.io
CONTENTSTACK_BRANCH=main
CONTENTSTACK_LOCALE=en-us
# Optional if VITE_CONTENTSTACK_ENVIRONMENT is already set (same publish target)
CONTENTSTACK_PUBLISH_ENVIRONMENT=

# Optional: only for npm run automate:entry
# CONTENTSTACK_AUTO_ENTRY_TITLE=

# Optional: custom manifest path (default scripts/content-types.manifest.json)
# CONTENTSTACK_MANIFEST_PATH=

# Optional: bootstrap without seed entry POSTs
# CONTENTSTACK_MANIFEST_SKIP_SEEDS=true

# Optional: duplicate seed title handling (set false to fail instead of skip+hydrate)
# CONTENTSTACK_MANIFEST_SKIP_DUPLICATE_SEEDS=false

# Optional: periodic batch size when manifest omits periodic.count
# CONTENTSTACK_PERIODIC_COUNT=1

# Optional: only if manifest uses taxonomy shorthand or __TAX_TERMS__ placeholders
# CONTENTSTACK_TAXONOMY_UID_CATEGORIES=
# CONTENTSTACK_TAXONOMY_TERMS_CATEGORIES=
